// Best Recursive Merge Sort Algorithm&#10;#include <vector>&#10;&#10;namespace MergeSort {&#10;&#10;/**&#10; * Merges two sorted subarrays arr[left..mid] and arr[mid+1..right]&#10; * into a single sorted subarray arr[left..right].&#10; * Uses temporary vector for stable merge.&#10; */&#10;void merge(std::vector<int>&amp; arr, size_t left, size_t mid, size_t right) {&#10;    // Temp vectors for left and right halves&#10;    std::vector<int> leftHalf(arr.begin() + left, arr.begin() + mid + 1);&#10;    std::vector<int> rightHalf(arr.begin() + mid + 1, arr.begin() + right + 1);&#10;&#10;    size_t i = 0, j = 0, k = left;;&#10;&#10;    // Merge the two halves&#10;    while (i < leftHalf.size() &amp;&amp; j < rightHalf.size()) {&#10;        if (leftHalf[i] <= rightHalf[j]) {&#10;            arr[k++] = leftHalf[i++];&#10;        } else {&#10;            arr[k++] = rightHalf[j++];&#10;        }&#10;    }&#10;&#10;    // Copy remaining elements of leftHalf, if any&#10;    while (i < leftHalf.size()) {&#10;        arr[k++] = leftHalf[i++];&#10;    }&#10;&#10;    // Copy remaining elements of rightHalf, if any&#10;    while (j < rightHalf.size()) {&#10;        arr[k++] = rightHalf[j++];&#10;    }&#10;;&#10;}/**&#10; * Best recursive Merge Sort.&#10; * Divides array into halves, recursively sorts, then merges.&#10; * Time: O(n log n), Space: O(n), Stable.&#10; * @param arr Vector to sort&#10; * @param left Starting index&#10; * @param right Ending index&#10; */&#10;void mergeSort(std::vector<int>&amp; arr, size_t left, size_t right) {&#10;    if (left >= right) return;  // Base case: 0 or 1 element&#10;&#10;    size_t mid = left + (right - left) / 2;  // Avoid overflow&#10;&#10;    mergeSort(arr, left, mid);      // Sort left half&#10;    mergeSort(arr, mid + 1, right); // Sort right half&#10;    merge(arr, left, mid, right);   // Merge sorted halves&#10;;&#10;}/**&#10; * Convenience wrapper to sort entire vector.&#10; */&#10;void sort(std::vector<int>&amp; arr) {&#10;    if (arr.size() <= 1) return;;&#10;    mergeSort(arr, 0, arr.size() - 1);&#10;}&#10;&#10;} // namespace MergeSort
